# =============================================================================
# Homework Answer Assistant — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# true  → in-memory demo data, no Supabase or AI required
# false → requires NEXT_PUBLIC_SUPABASE_URL and AI_API_KEY
DEMO_MODE=true

# ── Supabase (required when DEMO_MODE=false) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER prefix with NEXT_PUBLIC_, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Demo-mode admin login (only used when DEMO_MODE=true or Supabase not set) ─
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ── AI provider — Answer & Vision (Anthropic) ─────────────────────────────────
# Server-only secret. Leave empty to stay in Demo Mode.
AI_API_KEY=
AI_ANSWER_MODEL=claude-sonnet-4-6
AI_VISION_MODEL=claude-sonnet-4-6

# ── Embeddings provider (separate from AI answer provider) ────────────────────
# Uses OpenAI-compatible API. Leave empty to disable semantic search
# and fall back to trigram + keyword search (safe, fully functional).
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Rate limiting (optional Upstash Redis for multi-instance deployments) ─────
# Leave empty to use the in-memory rate limiter (single instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Safety limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=15
MAX_PDF_PAGES=10
MAX_QUESTIONS_PER_REQUEST=10
RATE_LIMIT_COUNT=20
RATE_LIMIT_WINDOW_SECONDS=600
SEARCH_CONFIDENCE_THRESHOLD=0.78
AI_TIMEOUT_MS=30000
FILE_PROCESSING_TIMEOUT_MS=60000
